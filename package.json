{
  "name": "enara-lighting-inventory",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:web": "npm run dev",
    "build": "npm run build:web",
    "build:web": "npm run clean && vite build",
    "build:pwa": "npm run build:web",
    "build:desktop": "node -e \"require('fs').rmSync('dist-tauri', { recursive: true, force: true })\" && vite build --config vite.desktop.config.ts",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "preview:web": "npm run preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "android:prepare": "npm run build:web && npx cap sync android",
    "android:open": "npx cap open android",
    "android:debug": "npm run android:prepare && cd android && java -Dandroid.overridePathCheck=true -classpath gradle/wrapper/gradle-wrapper.jar org.gradle.wrapper.GradleWrapperMain assembleDebug",
    "android:release": "npm run android:prepare && cd android && java -Dandroid.overridePathCheck=true -classpath gradle/wrapper/gradle-wrapper.jar org.gradle.wrapper.GradleWrapperMain assembleRelease",
    "cap:build": "npm run android:prepare",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build --no-bundle",
    "tauri:bundle": "npx tauri build",
    "tauri:info": "npx tauri info"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}