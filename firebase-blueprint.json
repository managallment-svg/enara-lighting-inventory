{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "Warehouse": {
      "title": "Warehouse",
      "description": "A physical warehouse location",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "location", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Item category (e.g., Low Voltage, Control Cables)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Item": {
      "title": "Item",
      "description": "An inventory item in a warehouse",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "warehouseId": { "type": "string" },
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["id", "warehouseId", "categoryId", "name", "quantity", "unit", "lastUpdated", "updatedBy"]
    },
    "Driver": {
      "title": "Driver",
      "description": "A driver who transports items",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Car": {
      "title": "Car",
      "description": "A vehicle used for transport",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" }
      },
      "required": ["id", "number"]
    },
    "Guard": {
      "title": "Guard",
      "description": "A guard or watchman",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/warehouses/{warehouseId}": {
      "schema": { "$ref": "#/entities/Warehouse" },
      "description": "Warehouses"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Item categories"
    },
    "/items/{itemId}": {
      "schema": { "$ref": "#/entities/Item" },
      "description": "Inventory items"
    },
    "/drivers/{driverId}": {
      "schema": { "$ref": "#/entities/Driver" },
      "description": "Drivers"
    },
    "/cars/{carId}": {
      "schema": { "$ref": "#/entities/Car" },
      "description": "Cars"
    },
    "/guards/{guardId}": {
      "schema": { "$ref": "#/entities/Guard" },
      "description": "Guards"
    }
  }
}
